<?xml version="1.0" encoding="utf-8" ?>
<!--
  MainScene: Root scene for the Hotel Del Live Cam channel.

  Remote control:
    Left / Right - switch cameras (or navigate dialog buttons)
    OK           - re-select current camera (or confirm dialog)
    Back         - show exit dialog (or dismiss it)

  Deep link content IDs:
    "south" or "0" -> Beach Camera South
    "north" or "1" -> Beach Camera North
-->
<component name="MainScene" extends="Scene">

  <interface>
    <!-- Passed in by main.brs on first launch -->
    <field id="launchArgs"   type="assocarray" onChange="onLaunchArgs" />
    <!-- Passed in by main.brs when a mid-session roInputEvent arrives -->
    <field id="inputArgs"    type="assocarray" onChange="onLaunchArgs" />
    <!-- Observed by main.brs; setting true causes screen.close() on main thread -->
    <field id="exitChannel"  type="boolean"    value="false" />
  </interface>

  <children>

    <!-- Full-screen video player (w/h set in BrightScript) -->
    <Video id="videoPlayer" translation="[0, 0]" />

    <!-- Header overlay — auto-hides 5s after playback starts -->
    <Group id="headerGroup">
      <Rectangle id="topBar" width="1920" height="110"
                 translation="[0, 0]" color="0x00000099" />
      <Label id="titleLabel" text="Hotel Del Live Cam"
             translation="[60, 28]" font="font:MediumBoldSystemFont"
             color="0xFFFFFFFF" />
      <Label id="liveLabel" text="LIVE"
             translation="[1800, 38]" font="font:SmallSystemFont"
             color="0xFF5555FF" />
      <Rectangle id="btnSouthBg" width="260" height="54"
                 translation="[660, 28]" color="0xFFFFFF33" />
      <Label id="btnSouth" text="Beach Camera South"
             translation="[672, 40]" font="font:SmallSystemFont"
             color="0xFFFFFFFF" />
      <Rectangle id="btnNorthBg" width="250" height="54"
                 translation="[940, 28]" color="0x00000000" />
      <Label id="btnNorth" text="Beach Camera North"
             translation="[952, 40]" font="font:SmallSystemFont"
             color="0xBBBBBBFF" />
    </Group>

    <!-- Status / loading / error message -->
    <Label id="statusLabel" text="Loading stream..."
           translation="[0, 520]" width="1920" horizAlign="center"
           font="font:MediumSystemFont" color="0xFFFFFFCC" />

    <!--
      Exit confirmation dialog — a custom overlay so it does NOT steal focus.
      Focus always stays on the Scene; onKeyEvent routes keys here when visible.
    -->
    <Group id="exitDialog" visible="false">
      <!-- Full-screen dim overlay -->
      <Rectangle width="1920" height="1080"
                 translation="[0, 0]" color="0x00000099" />
      <!-- Dialog card -->
      <Rectangle width="720" height="280"
                 translation="[600, 400]" color="0x111111EE" />
      <!-- Question -->
      <Label text="Exit Hotel Del Live Cam?"
             translation="[600, 430]" width="720"
             horizAlign="center" font="font:MediumBoldSystemFont"
             color="0xFFFFFFFF" />
      <!-- Keep Watching button -->
      <Rectangle id="btnKeepBg" width="280" height="64"
                 translation="[630, 520]" color="0xFFFFFF33" />
      <Label id="btnKeep" text="Keep Watching"
             translation="[630, 535]" width="280"
             horizAlign="center" font="font:SmallSystemFont"
             color="0xFFFFFFFF" />
      <!-- Exit button -->
      <Rectangle id="btnExitBg" width="180" height="64"
                 translation="[940, 520]" color="0x00000000" />
      <Label id="btnExit" text="Exit"
             translation="[940, 535]" width="180"
             horizAlign="center" font="font:SmallSystemFont"
             color="0xBBBBBBFF" />
      <!-- Hint -->
      <Label text="Left / Right to choose   OK to confirm   Back to cancel"
             translation="[600, 620]" width="720"
             horizAlign="center" font="font:SmallSystemFont"
             color="0x888888FF" />
    </Group>

  </children>

  <script type="text/brightscript" uri="pkg:/components/MainScene.brs" />
</component>
